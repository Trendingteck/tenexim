{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": [
      "ESNext",
      "DOM",
      "DOM.Iterable"
    ],
    "skipLibCheck": true,
    "strict": true,
    "forceConsistentCasingInFileNames": true,
    "noEmit": true,
    "esModuleInterop": true,
    "jsx": "react-jsx",
    "baseUrl": ".",
    "paths": {
      "@tenexim/ui": [
        "./packages/ui/src/index.ts"
      ],
      "@tenexim/database": [
        "./packages/database/src/index.ts"
      ],
      "@tenexim/auth": [
        "./packages/auth/src/index.ts"
      ],
      "@tenexim/types": [
        "./packages/types/src/index.ts"
      ],
      "@tenexim/ai": [
        "./packages/ai/src/index.ts"
      ],
      "@tenexim/configs/*": [
        "./packages/configs/*"
      ],
      "@tenexim/configs/tailwind": [
        "./packages/configs/tailwind/index.ts"
      ]
    }
  },
  "exclude": [
    "node_modules"
  ]
}