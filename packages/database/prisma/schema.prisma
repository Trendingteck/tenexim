generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url       = env("DATABASE_URL")
}

// --- USER & AUTH MODELS ---

enum Role {
  USER
  ADMIN
  ENTERPRISE
}

model User {
  id            String    @id @default(uuid())
  name          String?
  email         String    @unique
  passwordHash  String
  role          Role      @default(USER)
  avatar        String?
  
  // Onboarding & Trial tracking fields
  emailVerified DateTime? @map("email_verified")
  isTrial       Boolean   @default(true) @map("is_trial")
  trialEndsAt   DateTime? @map("trial_ends_at")
  
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  chatSessions  ChatSession[]

  @@index([email])
}

model ChatSession {
  id        String        @id @default(uuid())
  title     String
  userId    String
  user      User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  isPinned  Boolean       @default(false)
  messages  ChatMessage[]
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  @@index([userId])
}

model ChatMessage {
  id        String      @id @default(uuid())
  sessionId String
  session   ChatSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  role      String      // 'user' or 'assistant'
  content   String      @db.Text
  files     Json?       // To store array of file metadata (name, type, url/content)
  createdAt DateTime    @default(now())

  @@index([sessionId])
}

// --- SHIPMENT INTELLIGENCE MODELS ---

model Shipment {
  id            String    @id @default(uuid())

  // 1. Logistics & Documentation
  indianPort    String    @map("indian_port")
  beType        String?   @map("be_type")        
  boeNumber     String?   @map("boe_number")     
  boeDate       DateTime  @map("boe_date")       

  // 2. HS Codes (RITC)
  ritc2         String?   @map("ritc_2")         
  ritc4         String?   @map("ritc_4")         
  hsCode        String    @map("ritc_8")         

  // 3. Product & Quantity
  productDesc   String    @map("item_description") 
  quantity      Float     @map("qty")            
  unit          String    

  // 4. Values & Currency (All 7 valuation columns are now included)
  unitValueFc   Float     @map("unit_value_fc")  
  currency      String    @map("invoice_currency") 
  totalValueFc  Float     @map("total_value_fc") 
  unitValueUsd  Float     @map("unit_value_usd")  
  totalValueUsd Float     @map("total_value_usd") 
  unitValueInr  Float     @map("unit_value_inr")  
  totalValueInr Float     @map("total_value_inr") 
  duty          Float?    

  // 5. Importer Details
  importerName      String    @map("importer")            
  importerAddress   String?   @map("importer_address")    
  importerCityState String?   @map("city_state")          
  importerPin       String?   @map("pin_code")            
  importerPhone     String?   @map("importer_phone")      
  importerEmail     String?   @map("importer_email")      

  // 6. Supplier & Foreign Details
  supplierName      String    @map("supplier")            
  supplierAddress   String?   @map("supplier_address")    
  foreignPort       String?   @map("foreign_port")        
  originCountry     String    @map("origin_country")      

  createdAt DateTime @default(now())

  @@index([hsCode])
  @@index([importerName])
  @@index([supplierName])
  @@index([productDesc])
  @@index([boeDate])
  @@index([originCountry])
}