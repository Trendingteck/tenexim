{
    "name": "tenexim-monorepo",
    "private": true,
    "packageManager": "pnpm@10.14.0",
    "workspaces": [
        "apps/*",
        "packages/*"
    ],
    "scripts": {
        "dev": "turbo run dev",
        "build": "turbo run build",
        "lint": "turbo run lint",
        "format": "prettier --write \"**/*.{ts,tsx,md}\""
    },
    "devDependencies": {
        "@types/tailwindcss": "^3.1.0",
        "autoprefixer": "^10.4.17",
        "postcss": "^8.4.35",
        "prettier": "^3.0.0",
        "tailwindcss": "3.4.1",
        "turbo": "latest",
        "typescript": "^5.0.0"
    },
    "pnpm": {
        "overrides": {
            "react-smooth": "4.0.4"
        }
    }
}