{
    "name": "tenexim-monorepo",
    "private": true,
    "packageManager": "pnpm@10.14.0",
    "workspaces": [
        "apps/*",
        "packages/*"
    ],
    "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "verify-build": "pnpm build && pnpm lint",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "dashboard": "mprocs",
    "clean": "rimraf --glob \"**/.next\" \"**/.turbo\" \"**/.cache\" \"**/dist\" \"**/build\"",
    "clean:deep": "rimraf --glob \"**/.next\" \"**/.turbo\" \"**/.cache\" \"**/dist\" \"**/node_modules\" \"pnpm-lock.yaml\""
    },
    "devDependencies": {
        "@types/node": "^22.0.0",
        "@types/tailwindcss": "^3.1.0",
        "autoprefixer": "^10.4.17",
        "mprocs": "latest",
        "postcss": "^8.4.35",
        "prettier": "^3.0.0",
        "rimraf": "^6.1.2",
        "tailwindcss": "3.4.1",
        "turbo": "latest",
        "typescript": "^5.0.0"
    },
    "pnpm": {
        "overrides": {
            "react-smooth": "4.0.4"
        }
    },
    "dependencies": {
        "rehype-katex": "^7.0.1",
        "remark-math": "^6.0.0"
    }
}